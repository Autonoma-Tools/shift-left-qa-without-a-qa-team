# Sentry backfill handler environment.
# Copy to sentry-backfill/.env and fill in. NEVER commit the real .env.

# Shared secret configured on the Sentry webhook (used to verify HMAC signatures).
SENTRY_WEBHOOK_SECRET=replace-with-sentry-client-secret

# Slack Incoming Webhook URL for the channel that should receive alerts.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/REAL

# Autonoma API key used to authorize the test-backfill request.
AUTONOMA_API_KEY=replace-with-autonoma-api-key

# Optional overrides.
# PORT=3000
# SEVERITY_THRESHOLD=error
# AUTONOMA_BACKFILL_URL=https://api.autonoma.app/v1/tests/backfill
